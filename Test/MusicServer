-- Client request lagu
RequestSong.OnServerEvent:Connect(function(player, soundId)
    if not soundId then return end

    -- Rate limit: 1 request per 10 detik per player
    local lastRequest = player:GetAttribute("lastMusicRequest") or 0
    if tick() - lastRequest < 10 then
        return
    end
    player:SetAttribute("lastMusicRequest", tick())

    -- Cek queue tidak penuh
    if #songQueue >= MAX_QUEUE_SIZE then
        return
    end

    -- Bersihkan ID
    local cleanId = tostring(soundId):gsub("rbxassetid://", "")
    local numId = tonumber(cleanId)
    if not numId then return end

    -- Cek duplikat di queue
    for _, s in ipairs(songQueue) do
        if s.id == tostring(numId) then return end
    end
    if currentSong and currentSong.id == tostring(numId) then return end

    -- Get info lagu
    local info = getMusicInfo(numId)
    if not info then
        -- Fallback: buat entry minimal
        info = {
            id           = tostring(numId),
            title        = "Song " .. tostring(numId),
            artist       = player.DisplayName or player.Name,
            image        = "rbxassetid://71878240456460",
            duration     = "0:00",
            durationSecs = 300,
        }
    end
    info.requestedBy = player.DisplayName or player.Name

    table.insert(songQueue, info)
    print("[MusicServer] Queued:", info.title, "by", player.Name)

    broadcastQueue()

    -- Mulai putar jika belum ada yang main
    -- Jika sedang play (baik AutoPlay atau request), tunggu selesai dulu baru lanjut queue
    if not isPlaying then
        playNext()
    end
end)

-- Client vote skip
VoteSkip.OnServerEvent:Connect(function(player)
    if not currentSong then return end
    if skipVoters[player.UserId] then return end  -- sudah vote

    skipVoters[player.UserId] = true
    broadcastSkipVotes()

    local count = 0
    for _ in pairs(skipVoters) do count = count + 1 end

    -- Cek apakah sudah cukup vote
    local needed = math.min(SKIP_VOTES_REQUIRED, math.max(1, getPlayerCount()))
    if count >= needed then
        print("[MusicServer] Skip vote passed:", count, "/", needed)
        skipVoters = {}
        songEndedDebounce = false
        SongEnded:FireAllClients()
        task.wait(0.3)
        playNext()
    end
end)

-- Admin skip langsung
AdminSkip.OnServerEvent:Connect(function(player)
    if not isAdminPlayer(player) then return end
    if not currentSong then return end

    print("[MusicServer] Admin skip by:", player.Name)
    skipVoters = {}
    songEndedDebounce = false
    SongEnded:FireAllClients()
    task.wait(0.3)
    playNext()
end)

-- Admin pause/resume — hanya mute/unmute semua client, server tetap jalan
local isPaused = false
AdminPause.OnServerEvent:Connect(function(player)
    if not isAdminPlayer(player) then return end
    isPaused = not isPaused
    PauseState:FireAllClients(isPaused)
    print("[MusicServer] Admin", isPaused and "muted" or "unmuted", "music by:", player.Name)
end)

-- Client join: kirim state saat ini
GetSyncState.OnServerInvoke = function(player)
    local queueData = {}
    for _, song in ipairs(songQueue) do
        table.insert(queueData, {
            id          = song.id,
            title       = song.title,
            artist      = song.artist,
            image       = song.image,
            duration    = song.duration,
            requestedBy = song.requestedBy,
        })
    end

    local skipCount = 0
    for _ in pairs(skipVoters) do skipCount = skipCount + 1 end

    local currentData = nil
    if currentSong then
        local elapsed = tick() - currentSong.startTime
        currentData = {
            id           = currentSong.id,
            title        = currentSong.title,
            artist       = currentSong.artist,
            image        = currentSong.image,
            duration     = currentSong.duration,
            durationSecs = currentSong.durationSecs,
            startTime    = currentSong.startTime,
            elapsed      = elapsed,
            requestedBy  = currentSong.requestedBy,
            isAutoPlay   = currentSong.isAutoPlay or false,
        }
    end

    return {
        current    = currentData,
        queue      = queueData,
        skipCount  = skipCount,
        skipNeeded = SKIP_VOTES_REQUIRED,
        hasVoted   = skipVoters[player.UserId] == true,
    }
end

