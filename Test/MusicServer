-- Get semua lagu dari semua playlist (untuk remove popup)
GetAllSongsRemote.OnServerInvoke = function(player)
	if not isAdminPlayer(player) then return {} end
	local allSongs = {}
	local seenIds = {}
	for _, pl in ipairs(MusicData.Playlists) do
		for _, s in ipairs(pl.songs) do
			local sid = tostring(s.id)
			if not seenIds[sid] then
				seenIds[sid] = true
				table.insert(allSongs, {
