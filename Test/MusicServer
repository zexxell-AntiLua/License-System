local ClientSongEnded = getOrCreate(MusicRemotes, "ClientSongEnded", "RemoteEvent")   -- client -> server: lagu selesai di client
local AdminPause      = getOrCreate(MusicRemotes, "AdminPause",      "RemoteEvent")   -- client -> server: admin pause/resume
local PauseState      = getOrCreate(MusicRemotes, "PauseState",      "RemoteEvent")   -- server -> all: broadcast pause state
local GetMusicInfo    = getOrCreate(MusicRemotes, "GetMusicInfo",    "RemoteFunction") -- client -> server: get info lagu
local GetSyncState    = getOrCreate(MusicRemotes, "GetSyncState",    "RemoteFunction") -- client -> server: get state saat join

print("[MusicServer] Remotes created")

-- ============================================================
-- STATE
-- ============================================================
local SKIP_VOTES_REQUIRED = 10
local MAX_QUEUE_SIZE      = 20

local currentSong   = nil   -- {id, title, artist, image, duration, durationSecs, startTime, requestedBy}
local songQueue     = {}    -- array of song data (HANYA request player, bukan autoplay)
local skipVoters    = {}    -- [userId] = true
local isPlaying     = false
local playLoopConn  = nil

-- AutoPlay state (terpisah dari queue)
local autoPlayList     = {}    -- shuffled list lagu untuk autoplay
local autoPlayIndex    = 0     -- index lagu autoplay saat ini
local isAutoPlaySong   = false -- apakah lagu saat ini dari autoplay

-- Admin roles yang bisa skip langsung
local ADMIN_ROLES = {Owner=true, ["Co-Owner"]=true, Developer=true, Admin=true, Moderator=true}

-- ============================================================
-- HELPERS
-- ============================================================
local function isAdminPlayer(player)
    local role = RoleSystem:GetPlayerRole(player)
    if ADMIN_ROLES[role] then return true end
    if player.UserId == game.CreatorId then return true end
    -- Cek StaffList
    local staffNames = {luxwoldjalipa40=true, BeHumbble=true, rip_sc355=true}
    if staffNames[player.Name] then return true end
    return false
end

local function durationToSeconds(durStr)
    if not durStr then return 180 end
    local parts = durStr:split(":")
    if #parts == 2 then
        return (tonumber(parts[1]) or 0) * 60 + (tonumber(parts[2]) or 0)
    end
    return 180
end

local function secondsToDuration(secs)
    secs = math.floor(secs)
    local m = math.floor(secs / 60)
    local s = secs % 60
    return string.format("%d:%02d", m, s)
end

local function getPlayerCount()
    return #Players:GetPlayers()
end

local function broadcastQueue()
    local queueData = {}
    for i, song in ipairs(songQueue) do
        table.insert(queueData, {
            id          = song.id,
            title       = song.title,
            artist      = song.artist,
            image       = song.image,
            duration    = song.duration,
            requestedBy = song.requestedBy,
        })
    end
    UpdateQueue:FireAllClients(queueData)
end

local function broadcastSkipVotes()
    local count = 0
    for _ in pairs(skipVoters) do count = count + 1 end
    UpdateSkipVotes:FireAllClients(count, SKIP_VOTES_REQUIRED)
end

local function broadcastCurrentSong()
    if not currentSong then
        SyncMusic:FireAllClients(nil)
        return
    end
    local elapsed = tick() - currentSong.startTime
    SyncMusic:FireAllClients({
        id          = currentSong.id,
        title       = currentSong.title,
        artist      = currentSong.artist,
        image       = currentSong.image,
        duration    = currentSong.duration,
        durationSecs = currentSong.durationSecs,
        startTime   = currentSong.startTime,
        elapsed     = elapsed,
        requestedBy = currentSong.requestedBy,
        isAutoPlay  = currentSong.isAutoPlay or false,
    })
end

-- ============================================================
-- AUTOPLAY HELPERS
-- ============================================================
local function buildAutoPlaylist()
    local list = {}
    for _, playlist in ipairs(MusicData.Playlists) do
        for _, song in ipairs(playlist.songs) do
            local duplicate = false
            for _, existing in ipairs(list) do
                if existing.id == tostring(song.id) then
                    duplicate = true
                    break
                end
            end
            if not duplicate then
                table.insert(list, {
                    id           = tostring(song.id):gsub("rbxassetid://", ""),
                    title        = song.title or "Unknown",
                    artist       = song.artist or "Unknown",
                    image        = song.image or "rbxassetid://71878240456460",
                    duration     = song.duration or "0:00",
                    durationSecs = song.duration and durationToSeconds(song.duration) or 300,
                    requestedBy  = "AutoPlay",
                })
            end
        end
    end
    return list
end

local function shuffleTable(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
end

local function getNextAutoPlaySong()
    -- Rebuild & reshuffle jika habis atau kosong
    if #autoPlayList == 0 then
        autoPlayList = buildAutoPlaylist()
        shuffleTable(autoPlayList)
        autoPlayIndex = 0
    end
    if #autoPlayList == 0 then return nil end

    autoPlayIndex = autoPlayIndex + 1
    if autoPlayIndex > #autoPlayList then
        -- Shuffle ulang dan mulai dari awal
        shuffleTable(autoPlayList)
        autoPlayIndex = 1
    end
    return autoPlayList[autoPlayIndex]
end

-- ============================================================
-- PLAY NEXT SONG
-- Prioritas: queue player dulu → jika kosong → autoplay
-- ============================================================
local function playNext()
    skipVoters = {}

    local song = nil

    -- Prioritas 1: Ambil dari queue player
    if #songQueue > 0 then
        song = table.remove(songQueue, 1)
        isAutoPlaySong = false
    else
        -- Prioritas 2: AutoPlay (tidak masuk queue, langsung play)
        song = getNextAutoPlaySong()
        isAutoPlaySong = true
    end

    if not song then
        isPlaying = false
        currentSong = nil
        SyncMusic:FireAllClients(nil)
        return
    end

    currentSong = {
        id           = song.id,
        title        = song.title,
        artist       = song.artist,
        image        = song.image,
        duration     = song.duration,
        durationSecs = song.durationSecs or durationToSeconds(song.duration),
        startTime    = tick(),
        requestedBy  = song.requestedBy,
        isAutoPlay   = isAutoPlaySong,
    }
    isPlaying = true

    local source = isAutoPlaySong and "AutoPlay" or "Queue"
    print(string.format("[MusicServer] Now playing (%s): %s by %s", source, currentSong.title, currentSong.artist))

    -- Broadcast ke semua client
    broadcastCurrentSong()
    broadcastQueue()
    broadcastSkipVotes()

    -- Timer fallback: durasi + 90 detik (generous buffer)
    local songDuration = currentSong.durationSecs
    local startedAt   = currentSong.startTime
    local songId      = currentSong.id

    task.spawn(function()
        task.wait(songDuration + 90)
        if currentSong and currentSong.startTime == startedAt and currentSong.id == songId then
            if not isPaused then
                print("[MusicServer] Fallback timeout - forcing next")
                isPlaying = false
                SongEnded:FireAllClients()
                task.wait(1)
                playNext()
            end
        end
    end)
end

-- Client notify: lagu benar-benar selesai di Sound.Ended
local songEndedDebounce = false
ClientSongEnded.OnServerEvent:Connect(function(player)
    -- Hanya proses dari 1 client (yang pertama notify)
    if songEndedDebounce then return end
    if not currentSong then return end
    songEndedDebounce = true

    print("[MusicServer] Client notified song ended:", currentSong.title)
    isPlaying = false
    SongEnded:FireAllClients()
    task.wait(1)
    playNext()

    task.delay(2, function()
        songEndedDebounce = false
    end)
end)

-- ============================================================
-- GET MUSIC INFO VIA MARKETPLACE
-- ============================================================
local function getMusicInfo(soundId)
    -- Bersihkan ID (hapus prefix rbxassetid://)
    local cleanId = tostring(soundId):gsub("rbxassetid://", "")
    local numId = tonumber(cleanId)
    if not numId then return nil end

    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(numId, Enum.InfoType.Asset)
    end)

    if ok and info then
        -- Cek apakah ini audio asset
        if info.AssetTypeId == 3 then  -- 3 = Audio
            return {
                id       = tostring(numId),
                title    = info.Name or "Unknown",
                artist   = info.Creator and info.Creator.Name or "Unknown",
                image    = "rbxassetid://71878240456460",  -- default image
                duration = "0:00",  -- akan diupdate saat client load
                durationSecs = 300, -- default 5 menit
            }
        end
    end
    return nil
end

