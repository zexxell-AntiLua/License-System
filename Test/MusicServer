					title = s.title or "Unknown",
					artist = s.artist or "Unknown",
					image = s.image or "rbxassetid://71878240456460",
					playlist = pl.name,
				})
			end
		end
	end
	return allSongs
end

-- Admin hapus lagu dari semua playlist
RemoveSongFromPlaylist.OnServerInvoke = function(player, songId)
	if not isAdminPlayer(player) then
		return {success = false, message = "Not authorized"}
	end
	if not songId then
		return {success = false, message = "Missing song ID"}
	end

	local cleanId = tostring(songId):gsub("rbxassetid://", "")
	local removedTitle = nil

	-- Hapus dari semua playlist di runtime
	for _, pl in ipairs(MusicData.Playlists) do
		for i = #pl.songs, 1, -1 do
			if tostring(pl.songs[i].id) == cleanId then
				removedTitle = pl.songs[i].title
				table.remove(pl.songs, i)
			end
		end
	end

	-- Hapus dari DataStore semua playlist
	for _, pl in ipairs(MusicData.Playlists) do
		local storeKey = "playlist_" .. pl.name
		pcall(function()
			SavedMusicStore:UpdateAsync(storeKey, function(oldData)
				if not oldData then return oldData end
				for i = #oldData, 1, -1 do
					if tostring(oldData[i].id) == cleanId then
						table.remove(oldData, i)
					end
				end
				return oldData
			end)
		end)
	end

	-- Notify semua client
	for _, pl in ipairs(MusicData.Playlists) do
		local updatedSongs = {}
		for _, s in ipairs(pl.songs) do
			table.insert(updatedSongs, {
				id = tostring(s.id),
				title = s.title or "Unknown",
				artist = s.artist or "Unknown",
				image = s.image or "rbxassetid://71878240456460",
				verified = s.verified or false,
			})
		end
		PlaylistUpdated:FireAllClients(pl.name, updatedSongs)
	end

	print("[MusicServer] Admin", player.Name, "removed song", removedTitle or cleanId)
	return {success = true, message = "Removed: " .. (removedTitle or cleanId)}
end

-- Admin tambah lagu ke playlist dan simpan ke DataStore
AddSongToPlaylist.OnServerInvoke = function(player, songCode, playlistName, customName)
	if not isAdminPlayer(player) then
		return {success = false, message = "Not authorized"}
	end

	if not songCode or not playlistName then
		return {success = false, message = "Missing data"}
	end

	local cleanId = tostring(songCode):gsub("rbxassetid://", "")
	local numId = tonumber(cleanId)
	if not numId then
		return {success = false, message = "Invalid music code"}
	end

	-- Get info dari MarketplaceService
	local info = getMusicInfo(numId)
	if not info then
		info = {
			id = tostring(numId),
			title = "Song " .. tostring(numId),
			artist = "Unknown",
			image = "rbxassetid://71878240456460",
			duration = "0:00",
		}
	end

	-- Override nama jika admin memberikan custom name
	if customName and customName ~= "" then
		info.title = customName
	end

	-- Simpan ke DataStore
	local storeKey = "playlist_" .. playlistName
	local ok, err = pcall(function()
		SavedMusicStore:UpdateAsync(storeKey, function(oldData)
			oldData = oldData or {}
			-- Cek duplikat
			for _, s in ipairs(oldData) do
				if s.id == info.id then return oldData end
			end
			table.insert(oldData, {
				id = info.id,
				title = info.title,
				artist = info.artist,
				image = info.image,
				addedBy = player.Name,
				addedAt = os.time(),
			})
			return oldData
		end)
	end)

	if not ok then
		warn("[MusicServer] DataStore save failed:", err)
		return {success = false, message = "DataStore error"}
	end

	-- Tambah ke MusicData runtime (agar langsung terlihat tanpa restart)
	for _, pl in ipairs(MusicData.Playlists) do
		if pl.name == playlistName then
			-- Cek duplikat
			local exists = false
			for _, s in ipairs(pl.songs) do
				if tostring(s.id) == info.id then exists = true break end
			end
			if not exists then
				table.insert(pl.songs, {
					id = info.id,
					title = info.title,
					artist = info.artist,
					image = info.image,
					verified = true,
				})
			end
			break
		end
	end

	print("[MusicServer] Admin", player.Name, "added song", info.title, "to playlist", playlistName)

	-- Notify semua client bahwa playlist berubah
	local updatedSongs = {}
	for _, pl in ipairs(MusicData.Playlists) do
		if pl.name == playlistName then
			for _, s in ipairs(pl.songs) do
				table.insert(updatedSongs, {
					id = tostring(s.id),
					title = s.title or "Unknown",
					artist = s.artist or "Unknown",
					image = s.image or "rbxassetid://71878240456460",
					verified = s.verified or false,
				})
			end
			break
		end
	end
	PlaylistUpdated:FireAllClients(playlistName, updatedSongs)

	return {success = true, message = "Song added: " .. info.title}
end

-- Get saved songs dari DataStore
GetSavedSongs.OnServerInvoke = function(player, playlistName)
	if not playlistName then return {} end
	local storeKey = "playlist_" .. playlistName
	local ok, data = pcall(function()
		return SavedMusicStore:GetAsync(storeKey)
	end)
	if ok and data then return data end
	return {}
end

-- Load saved songs ke MusicData saat server start
task.spawn(function()
	for _, pl in ipairs(MusicData.Playlists) do
		local storeKey = "playlist_" .. pl.name
		local ok, data = pcall(function()
			return SavedMusicStore:GetAsync(storeKey)
		end)
		if ok and data and type(data) == "table" then
			for _, saved in ipairs(data) do
				local exists = false
				for _, s in ipairs(pl.songs) do
					if tostring(s.id) == tostring(saved.id) then exists = true break end
				end
				if not exists then
					table.insert(pl.songs, {
						id = saved.id,
						title = saved.title or "Unknown",
						artist = saved.artist or "Unknown",
						image = saved.image or "rbxassetid://71878240456460",
						verified = true,
					})
				end
			end
			print("[MusicServer] Loaded", #data, "saved songs for playlist:", pl.name)
		end
	end
end)

print("[MusicServer] Loaded successfully")

