-- ============================================================
-- REMOTES SETUP
-- ============================================================
local MusicRemotes = ReplicatedStorage:FindFirstChild("MusicRemotes")
if not MusicRemotes then
    MusicRemotes = Instance.new("Folder")
    MusicRemotes.Name = "MusicRemotes"
    MusicRemotes.Parent = ReplicatedStorage
end

local function getOrCreate(parent, name, className)
    local obj = parent:FindFirstChild(name)
    if not obj then
        obj = Instance.new(className, parent)
        obj.Name = name
    end
    return obj
end

-- RemoteEvents
local SyncMusic       = getOrCreate(MusicRemotes, "SyncMusic",       "RemoteEvent")   -- server -> all: sync state
local RequestSong     = getOrCreate(MusicRemotes, "RequestSong",     "RemoteEvent")   -- client -> server: request lagu
local VoteSkip        = getOrCreate(MusicRemotes, "VoteSkip",        "RemoteEvent")   -- client -> server: vote skip
local AdminSkip       = getOrCreate(MusicRemotes, "AdminSkip",       "RemoteEvent")   -- client -> server: admin skip
local UpdateQueue     = getOrCreate(MusicRemotes, "UpdateQueue",     "RemoteEvent")   -- server -> all: update queue UI
local UpdateSkipVotes = getOrCreate(MusicRemotes, "UpdateSkipVotes", "RemoteEvent")   -- server -> all: update vote count
